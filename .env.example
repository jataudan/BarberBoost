# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Stripe ────────────────────────────────────────────────────────────────────
# Keys from: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Webhook secret from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Price IDs from: Stripe Dashboard → Products (create one per plan)
STRIPE_STARTER_PRICE_ID=price_your_starter_price_id
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_EMPIRE_PRICE_ID=price_your_empire_price_id

# ── Resend (transactional email) ──────────────────────────────────────────────
# API key from: resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key
# Verified sender address (must match a domain verified in Resend)
RESEND_FROM_EMAIL=noreply@barberboost.app
# Recipient for contact-form submissions — falls back to SUPPORT_EMAIL then a hardcoded default
CONTACT_EMAIL=support@barberboost.app
# General support address — also used as contact-form fallback
SUPPORT_EMAIL=support@barberboost.app
# Internal address to receive new-signup alert emails
NOTIFY_EMAIL=barberboost.app@gmail.com

# ── Anthropic (AI Copy — Empire plan feature) ─────────────────────────────────
# Optional — only required if using the AI copy assistant feature
# API key from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# ── App ───────────────────────────────────────────────────────────────────────
# Your production URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── Twilio (WhatsApp reminders) ───────────────────────────────────────────────
# SID and Auth Token from: Twilio Console → Account → API keys & tokens
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# WhatsApp-enabled number in E.164 with whatsapp: prefix, e.g. whatsapp:+447700900000
# Must be a Twilio-approved WhatsApp Business number (not the sandbox)
TWILIO_WHATSAPP_FROM=whatsapp:+447770144717

# ── Cron ──────────────────────────────────────────────────────────────────────
# Random secret used to authenticate Vercel Cron calls → /api/cron/reminders
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_cron_secret_here